+// Cruce automático: si el "Contacto" de la persona es un email que coincide con
+// el email (de Google) de algún perfil de login, se autovincula sin tener que elegirlo a mano.
+function matchPerfilByEmail(contactoRaw){
+  const v=(contactoRaw||"").trim().toLowerCase();
+  if(!v||!v.includes("@"))return null;
+  return PERFILES_LITE.find(pf=>pf.email&&pf.email===v)||null;
+}
+function autoMatchPerfilByContacto(){
+  const sel=document.getElementById("per-f-perfil");
+  if(!sel||sel.value)return; // ya hay uno elegido a mano, no lo tocamos
+  const match=matchPerfilByEmail(document.getElementById("per-f-contacto").value);
+  if(match){
+    populatePerfilSelect(match.id);
+    toast("🔗 Vinculado automáticamente a "+match.nombre+" (por email)");
+  }
+}

+.pl-carga-modal-list{overflow-y:auto;padding:10px 12px 14px;}
+.pl-carga-drill-item{display:flex;align-items:center;justify-content:space-between;padding:9px 10px;border-radius:7px;font-size:12px;color:#E4E1F7;cursor:pointer;transition:background .12s;}

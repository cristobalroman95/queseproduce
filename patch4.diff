+/* ── CARGA DE EQUIPO: modal drill-down ── */
+.pl-carga-modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:900;display:flex;align-items:center;justify-content:center;}
+.pl-carga-modal-box{background:var(--surface2);border:0.5px solid var(--border-soft);border-radius:14px;padding:0;min-width:300px;max-width:420px;width:90%;max-height:70vh;display:flex;flex-direction:column;overflow:hidden;}
+.pl-carga-modal-hdr{display:flex;align-items:flex-start;justify-content:space-between;padding:18px 20px 14px;border-bottom:0.5px solid var(--border-soft);}
+.pl-carga-modal-persona{font-size:13px;font-weight:700;color:#E4E1F7;}
+.pl-carga-modal-periodo{font-size:11px;color:#9690C2;margin-top:2px;}
+.pl-carga-modal-close{background:none;border:none;color:#888;font-size:16px;cursor:pointer;padding:0;line-height:1;flex-shrink:0;}

@@ -454,6 +454,19 @@ h1,h2,h3,.topbar-title,.land-h1,.sidebar-logo h1,.login-logo{font-family:var(--f
 .pl-carga-av{width:24px;height:24px;border-radius:50%;background:var(--p100);color:var(--p800);font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;}

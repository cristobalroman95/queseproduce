+// ══════════════════════════════════════════════
+// EQUIPO: personas (registro real) + asignaciones (equipo de trabajo por show/contenido)
+// ══════════════════════════════════════════════
+
+const PERSONA_AREAS=['Producción','Técnica','Creativo','Marketing','Artístico'];
+let PERSONAS=[];
+let ASIGNACIONES=[];
+let editingPersonaId=null;
+
+async function loadPersonas(){
+  try{
+    const {data,error}=await sb.from("personas").select("*").order("id",{ascending:true});
+    if(error){ toast("⚠️ Error cargando equipo: "+error.message); return []; }
+    return (data||[]).map(p=>({
+      id:p.id, nombre:p.nombre||"", cargo:p.cargo||"", area:p.area||"Producción",
+      contacto:p.contacto||"", activo:p.activo!==false, nota:p.nota||"",
+    }));
+  }catch(e){ toast("⚠️ Error de conexión cargando equipo"); return []; }
+}
+
+async function loadAsignaciones(){
+  try{
+    const {data,error}=await sb.from("asignaciones").select("*");
+    if(error){ toast("⚠️ Error cargando asignaciones de equipo: "+error.message); return []; }
+    return (data||[]).map(a=>({
+      id:a.id, entityType:a.entity_type, entityId:a.entity_id, personaId:a.persona_id,
+      rol:a.rol_contexto||"", tarea:a.tarea||"", viaja:!!a.viaja, estado:a.estado||"confirmado",
+    }));
+  }catch(e){ toast("⚠️ Error de conexión cargando asignaciones de equipo"); return []; }
+}
+
+// ── CRUD de personas (sección Equipo) ──
+function showAddPersonaForm(){
+  editingPersonaId=null;
+  document.getElementById("persona-add-area").style.display="block";
+  ["per-f-nombre","per-f-cargo","per-f-contacto"].forEach(id=>{const el=document.getElementById(id);if(el)el.value="";});
+  document.getElementById("per-f-area").value="Producción";
+}
+function hideAddPersonaForm(){
+  document.getElementById("persona-add-area").style.display="none";
+  editingPersonaId=null;
+}
+function editPersona(id){
+  const p=PERSONAS.find(x=>x.id===id);
+  if(!p)return;
+  editingPersonaId=id;
+  document.getElementById("persona-add-area").style.display="block";
+  document.getElementById("per-f-nombre").value=p.nombre;
+  document.getElementById("per-f-cargo").value=p.cargo;
+  document.getElementById("per-f-area").value=p.area;
+  document.getElementById("per-f-contacto").value=p.contacto;
+}
+async function savePersona(){
+  const nombre=document.getElementById("per-f-nombre").value.trim();
+  if(!nombre){toast("⚠️ Ingresá un nombre.");return;}
+  const payload={
+    nombre,
+    cargo:document.getElementById("per-f-cargo").value.trim(),
+    area:document.getElementById("per-f-area").value,
+    contacto:document.getElementById("per-f-contacto").value.trim(),
+  };
+  try{
+    if(editingPersonaId!=null){
+      const {error}=await sb.from("personas").update(payload).eq("id",editingPersonaId);
+      if(error){toast("⚠️ Error guardando: "+error.message);return;}
+      const idx=PERSONAS.findIndex(p=>p.id===editingPersonaId);
+      if(idx>=0)PERSONAS[idx]={...PERSONAS[idx],...payload};
+      toast("✅ Persona actualizada");
+    } else {
+      const {data,error}=await sb.from("personas").insert({...payload,activo:true}).select().single();
+      if(error){toast("⚠️ Error guardando: "+error.message);return;}
+      PERSONAS.push({id:data.id,nombre:data.nombre,cargo:data.cargo||"",area:data.area,contacto:data.contacto||"",activo:true,nota:""});
+      toast("✅ Persona agregada");
+    }
+  }catch(e){toast("⚠️ Error de conexión guardando persona");return;}
+  hideAddPersonaForm();
+  buildEquipo();
+}
+async function togglePersonaActivo(id){
+  const p=PERSONAS.find(x=>x.id===id);
+  if(!p)return;
+  const nuevoActivo=!p.activo;
+  try{
+    const {error}=await sb.from("personas").update({activo:nuevoActivo}).eq("id",id);
+    if(error){toast("⚠️ Error actualizando: "+error.message);return;}
+    p.activo=nuevoActivo;
+    toast(nuevoActivo?"✅ Marcada como activa":"💤 Marcada como inactiva");
+  }catch(e){toast("⚠️ Error de conexión");return;}
+  buildEquipo();
+}
+async function deletePersona(id){
+  const p=PERSONAS.find(x=>x.id===id);
+  if(!p)return;
+  if(!confirm("¿Eliminar a "+p.nombre+" del equipo? También se quitará de cualquier show/contenido donde esté asignada."))return;
+  try{
+    const {error}=await sb.from("personas").delete().eq("id",id);
+    if(error){toast("⚠️ Error eliminando: "+error.message);return;}
+    PERSONAS=PERSONAS.filter(x=>x.id!==id);
+    ASIGNACIONES=ASIGNACIONES.filter(a=>a.personaId!==id); // cascade ya las borró en DB
+    toast("🗑 Persona eliminada");
+  }catch(e){toast("⚠️ Error de conexión eliminando persona");return;}
+  buildEquipo();
+  renderFullDetailIfOpen();
+}
+
+function buildEquipo(){
+  const canEdit=currentUser&&ROLE_DEFS[currentUser.rol]?.canEdit;
+  const addBtn=document.getElementById("persona-add-btn");
+  if(addBtn)addBtn.style.display=canEdit?"flex":"none";
+  const grid=document.getElementById("personas-grid");
+  if(!grid)return;
+  if(!PERSONAS.length){
+    grid.innerHTML="<div style='font-size:11px;color:#aaa;'>Todavía no hay personas registradas. "+(canEdit?"Usá '+ Agregar persona'.":"")+"</div>";
+    return;
+  }
+  const activos=PERSONAS.filter(p=>p.activo);
+  const inactivos=PERSONAS.filter(p=>!p.activo);
+  grid.innerHTML=[...activos,...inactivos].map(p=>`
+    <div class="team-card ${p.activo?"":"inactivo"}">
+      <div class="team-av">${(p.nombre||"?").charAt(0).toUpperCase()}</div>
+      <div class="ti" style="flex:1;">
+        <div class="tn">${p.nombre}${p.activo?"":" <span style='font-size:9px;color:#bbb;'>(inactiva)</span>"}</div>
+        <div class="tr">${p.cargo||"—"}</div>
+        <div class="ta">${p.area}${p.contacto?" · "+p.contacto:""}</div>
+      </div>
+      ${canEdit?`<div style="display:flex;flex-direction:column;gap:4px;">
+        <button class="btn" style="font-size:9px;padding:2px 7px;" onclick="editPersona(${p.id})">Editar</button>
+        <button class="btn" style="font-size:9px;padding:2px 7px;" onclick="togglePersonaActivo(${p.id})">${p.activo?"Desactivar":"Activar"}</button>
+        <button class="btn" style="font-size:9px;padding:2px 7px;color:var(--r600);border-color:var(--r100);" onclick="deletePersona(${p.id})">Eliminar</button>
+      </div>`:""}
+    </div>`).join("");
+}
+
+// ── Asignaciones genéricas (equipo de trabajo por show o contenido) ──
+function getAsignaciones(entityType,entityId){
+  return ASIGNACIONES.filter(a=>a.entityType===entityType&&String(a.entityId)===String(entityId));
+}
+
+// Estado temporal de edición mientras se arma la selección, antes de guardar
+let eqEditState={};
+function eqKey(entityType,entityId){return entityType+":"+entityId;}
+
+function equipoAsignadoHTML(entityType,entityId,canEdit){
+  const key=eqKey(entityType,entityId);
+  if(!eqEditState[key]){
+    // Inicializar desde lo ya guardado
+    eqEditState[key]=getAsignaciones(entityType,entityId).map(a=>({personaId:a.personaId,rol:a.rol,tarea:a.tarea,viaja:a.viaja}));
+  }
+  const sel=eqEditState[key];
+  const activos=PERSONAS.filter(p=>p.activo);
+  if(!activos.length){
+    return `<div class="card"><h3>Equipo asignado</h3><p style="font-size:11px;color:#aaa;margin-top:8px;">No hay personas activas registradas en Equipo todavía.</p></div>`;
+  }
+  const chips=activos.map(p=>{
+    const isSel=sel.some(s=>s.personaId===p.id);
+    return `<div class="eq-chip ${isSel?"selected":""}" ${canEdit?`onclick="toggleEquipoPersona('${entityType}',${entityId},${p.id})"`:""}>${p.nombre}</div>`;
+  }).join("");
+  const rows=sel.map(s=>{
+    const p=PERSONAS.find(x=>x.id===s.personaId);
+    if(!p)return"";
+    return `<div class="eq-row">
+      <input type="text" ${canEdit?"":"disabled"} placeholder="Rol en este contexto (ej: Sonidista)" value="${s.rol||""}" onchange="updateEquipoField('${entityType}',${entityId},${p.id},'rol',this.value)">
+      <input type="text" ${canEdit?"":"disabled"} placeholder="Tarea / nota (opcional)" value="${s.tarea||""}" onchange="updateEquipoField('${entityType}',${entityId},${p.id},'tarea',this.value)">
+      <label><input type="checkbox" ${s.viaja?"checked":""} ${canEdit?"":"disabled"} onchange="updateEquipoField('${entityType}',${entityId},${p.id},'viaja',this.checked)"> ✈️ Viaja</label>
+    </div>`;
+  }).join("");
+  return `<div class="card">
+    <h3>Equipo asignado</h3>
+    <div style="font-size:11px;color:#888;margin:6px 0 10px;">${canEdit?"Tocá una persona para sumarla o sacarla del equipo de este show/contenido.":"Personas asignadas a este show/contenido."}</div>
+    <div style="display:flex;flex-wrap:wrap;gap:6px;">${chips}</div>
+    ${rows?`<div style="margin-top:10px;">${rows}</div>`:""}
+    ${canEdit?`<div style="margin-top:12px;"><button class="btn btn-primary" style="font-size:11px;" onclick="saveEquipoAsignado('${entityType}',${entityId})">Guardar equipo</button></div>`:""}
+  </div>`;
+}
+
+function toggleEquipoPersona(entityType,entityId,personaId){
+  const key=eqKey(entityType,entityId);
+  const sel=eqEditState[key]||[];
+  const idx=sel.findIndex(s=>s.personaId===personaId);
+  if(idx>=0)sel.splice(idx,1);
+  else sel.push({personaId,rol:"",tarea:"",viaja:false});
+  eqEditState[key]=sel;
+  rerenderEquipoAsignado(entityType,entityId);
+}
+function updateEquipoField(entityType,entityId,personaId,field,value){
+  const key=eqKey(entityType,entityId);
+  const sel=eqEditState[key]||[];
+  const item=sel.find(s=>s.personaId===personaId);
+  if(item)item[field]=value;
+}
+function rerenderEquipoAsignado(entityType,entityId){
+  if(entityType==="show"&&fullDetailIdx!==null&&fullDetailActiveTab==="equipo"){
+    renderFullDetailIfOpen();
+  }
+}
+
+async function persistAsignaciones(entityType,entityId,items){
+  try{
+    const {error:delErr}=await sb.from("asignaciones").delete().eq("entity_type",entityType).eq("entity_id",entityId);
+    if(delErr){toast("⚠️ Error actualizando equipo: "+delErr.message);return false;}
+    ASIGNACIONES=ASIGNACIONES.filter(a=>!(a.entityType===entityType&&String(a.entityId)===String(entityId)));
+    if(items.length){
+      const payload=items.map(it=>({entity_type:entityType,entity_id:entityId,persona_id:it.personaId,rol_contexto:it.rol||"",tarea:it.tarea||"",viaja:!!it.viaja,estado:"confirmado"}));
+      const {data:inserted,error:insErr}=await sb.from("asignaciones").insert(payload).select();
+      if(insErr){toast("⚠️ Error guardando equipo: "+insErr.message);return false;}
+      (inserted||[]).forEach(row=>{
+        ASIGNACIONES.push({id:row.id,entityType:row.entity_type,entityId:row.entity_id,personaId:row.persona_id,rol:row.rol_contexto||"",tarea:row.tarea||"",viaja:!!row.viaja,estado:row.estado});
+      });
+    }
+    return true;
+  }catch(e){toast("⚠️ Error de conexión guardando equipo");return false;}
+}
+
+async function saveEquipoAsignado(entityType,entityId){
+  const key=eqKey(entityType,entityId);
+  const items=eqEditState[key]||[];
+  const ok=await persistAsignaciones(entityType,entityId,items);
+  if(!ok)return;
+  toast("✅ Equipo actualizado");
+  delete eqEditState[key]; // fuerza reconstrucción desde ASIGNACIONES ya actualizado
+  rerenderEquipoAsignado(entityType,entityId);
+}

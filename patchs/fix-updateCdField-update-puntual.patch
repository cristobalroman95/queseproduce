From 3df726eff23af1c924571a337b9f5a3e0c2fae08 Mon Sep 17 00:00:00 2001
From: Claude <claude@anthropic.com>
Date: Sun, 21 Jun 2026 21:19:17 +0000
Subject: [PATCH] fix: updateCdField usa UPDATE puntual en vez de
 delete+reinsert
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Causa raíz del bug 'Pieza no encontrada' y congelamiento al editar fechas:
- saveContenidoData() hace DELETE de toda la tabla y reinserta con IDs nuevos
- cdDetailId quedaba apuntando al ID viejo que ya no existía en CONTENIDO
- El Gantt se regeneraba completo en cada keystroke (costoso, congelaba)

Fix:
- updateCdField ahora llama saveCdCampo(item, field) en vez de saveContenidoData()
- saveCdCampo hace sb.from('contenido_digital').update({campo}).eq('id', item.id)
  → UPDATE puntual de solo la columna modificada, el id nunca cambia
- CD_FIELD_MAP mapea JS field name -> columna DB
- updateCdField ya no llama buildContenido() si la vista activa es Gantt
- saveContenidoData() sigue usándose solo para alta nueva (modal) y baja (delete),
  que son los únicos casos donde el delete+reinsert tiene sentido
---
 index.html | 55 +++++++++++++++++++++++++++++++++++++++++++-----------
 1 file changed, 44 insertions(+), 11 deletions(-)

diff --git a/index.html b/index.html
index a39b13b..9b93d7d 100644
--- a/index.html
+++ b/index.html
@@ -5459,10 +5459,19 @@ function escHtml(str){
   return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
 }
 
+// Mapa JS field -> columna DB
+const CD_FIELD_MAP={
+  nombre:'nombre', tipo:'tipo', plataforma:'plataforma', estado:'estado',
+  responsable:'responsable', fecha:'fecha', fechaInicio:'fecha_inicio',
+  fechaIdea:'fecha_idea', url:'url', notas:'notas', showIdx:'show_id'
+};
+
 function updateCdField(id,field,rawValue){
   const item=CONTENIDO.find(c=>String(c.id)===String(id));
   if(!item)return;
   const value=typeof rawValue==='string'?rawValue.trim():rawValue;
+
+  // Actualizar memoria
   if(field==='showIdx'){
     item.showIdx=value!==''&&value!==null?parseInt(value):null;
   } else if(field==='fechaIdea'){
@@ -5474,20 +5483,44 @@ function updateCdField(id,field,rawValue){
   } else {
     item[field]=value;
   }
-  // Refresh header in case name/tipo/plataforma changed
+
+  // Refresh header si cambio nombre/tipo/plataforma
   _refreshCdDetailHeader(item);
-  // Persist
-  saveContenidoData();
-  // Refresh main view if visible
-  buildContenido();
-  renderFullDetailIfOpen();
+
+  // UPDATE puntual por id — NO borra+reinserta, id nunca cambia
+  saveCdCampo(item, field);
+
+  // Refrescar vista principal solo si no es Gantt (el Gantt se refresca al cerrar la ficha)
+  const view=document.getElementById('cd-view-sel')?.value||'kanban';
+  if(view!=='gantt') buildContenido();
 }
 
-async function saveCdCampo(id){
-  // Direct update of a single contenido_digital row by id (avoids full delete+reinsert for field edits)
-  // Falls through to the chain-based persistContenido for now (safe, simpler)
-  // Future: replace with sb.from('contenido_digital').update({...}).eq('id', id) for efficiency
-  saveContenidoData();
+async function saveCdCampo(item, changedField){
+  const dbField=CD_FIELD_MAP[changedField];
+  let dbValue;
+  if(changedField==='showIdx'){
+    dbValue=item.showIdx!=null?(SHOWS[item.showIdx]?.id||null):null;
+  } else if(changedField==='fecha'||changedField==='fechaInicio'||changedField==='fechaIdea'){
+    dbValue=item[changedField]||null;
+  } else {
+    dbValue=item[changedField]||'';
+  }
+
+  // Si el campo esta mapeado, solo actualiza esa columna; si no, full update
+  const payload=dbField?{[dbField]:dbValue}:{
+    nombre:item.nombre||'',tipo:item.tipo||'',plataforma:item.plataforma||'',
+    estado:item.estado||'',responsable:item.responsable||'',
+    fecha:item.fecha||null,fecha_inicio:item.fechaInicio||null,fecha_idea:item.fechaIdea||null,
+    url:item.url||'',notas:item.notas||'',
+    show_id:item.showIdx!=null?(SHOWS[item.showIdx]?.id||null):null,
+  };
+
+  try{
+    const {error}=await sb.from('contenido_digital').update(payload).eq('id',item.id);
+    if(error)toast('\u26a0\ufe0f Error guardando campo: '+error.message);
+  }catch(e){
+    toast('\u26a0\ufe0f Error de conexion al guardar');
+  }
 }
 
 function deleteCdFromDetail(id){

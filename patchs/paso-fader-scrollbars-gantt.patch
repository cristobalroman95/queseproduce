diff --git a/index.html b/index.html
index 39baeff..eef0d71 100644
--- a/index.html
+++ b/index.html
@@ -309,6 +309,35 @@ h1,h2,h3,.topbar-title,.land-h1,.sidebar-logo h1,.login-logo{font-family:var(--f
   .gantt-control-item input[type=range]{width:90px;}
   .gantt-labels{width:120px !important;}
 }
+/* Scrollbars del Gantt (los que mueven la tabla) — más gruesos y fáciles de agarrar, estilo fader */
+.gantt-scroll,.gantt-labels{
+  scrollbar-width:auto;
+  scrollbar-color:var(--p400) var(--g50);
+}
+.gantt-scroll::-webkit-scrollbar,.gantt-labels::-webkit-scrollbar{
+  width:20px;height:20px;
+}
+.gantt-scroll::-webkit-scrollbar-track,.gantt-labels::-webkit-scrollbar-track{
+  background:var(--g50);
+  border-radius:10px;
+}
+.gantt-scroll::-webkit-scrollbar-thumb,.gantt-labels::-webkit-scrollbar-thumb{
+  background:linear-gradient(180deg,var(--p200),var(--p400));
+  border-radius:10px;
+  border:3px solid var(--g50);
+  background-clip:padding-box;
+}
+.gantt-scroll::-webkit-scrollbar-thumb:horizontal{min-width:64px;}
+.gantt-scroll::-webkit-scrollbar-thumb:vertical,.gantt-labels::-webkit-scrollbar-thumb:vertical{min-height:64px;}
+.gantt-scroll::-webkit-scrollbar-thumb:hover,.gantt-labels::-webkit-scrollbar-thumb:hover{
+  background:linear-gradient(180deg,var(--p100),var(--p200));
+  background-clip:padding-box;
+}
+.gantt-scroll::-webkit-scrollbar-thumb:active,.gantt-labels::-webkit-scrollbar-thumb:active{
+  background:var(--p600);
+  background-clip:padding-box;
+}
+.gantt-scroll::-webkit-scrollbar-corner{background:var(--g50);}
 /* ── ROADMAP ── */

+  const cat=document.getElementById('cdref-upload-cat')?.value||CD_REF_CATS[0];
+  let ok=0;
+  for(const f of files){const r=await saveCdRefFile(contenidoId,f,cat,f.name.replace(/\.[^.]+$/,''));if(r)ok++;}
+  await renderCdRefGrid(contenidoId);

+async function updateCdTaskEtapa(contenidoId,taskId,value){
+  const tasks=_cdTasksCache[contenidoId]||[];
+  const task=tasks.find(t=>t.id===taskId);
+  if(!task||task.etapa===value.trim())return;
+  task.etapa=value.trim();
+  await sb.from('contenido_tasks').update({etapa:task.etapa}).eq('id',taskId);
+}
+
+async function updateCdTaskNotas(contenidoId,taskId,value){
+  const tasks=_cdTasksCache[contenidoId]||[];
+  const task=tasks.find(t=>t.id===taskId);
+  const v=value.trim()==='—'?'':value.trim();
+  if(!task||task.notas===v)return;
+  task.notas=v;
+  await sb.from('contenido_tasks').update({notas:task.notas}).eq('id',taskId);
+}

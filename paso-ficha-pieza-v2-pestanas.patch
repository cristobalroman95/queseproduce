+async function cycleCdTaskEstado(contenidoId,taskId){
+  const tasks=_cdTasksCache[contenidoId]||[];
+  const task=tasks.find(t=>t.id===taskId);
+  if(!task)return;
+  const idx=CD_TASK_ESTADOS.indexOf(task.estado);
+  const next=CD_TASK_ESTADOS[(idx+1)%CD_TASK_ESTADOS.length];
+  const {error}=await sb.from('contenido_tasks').update({estado:next}).eq('id',taskId);
+  if(error){toast('⚠️ Error actualizando estado: '+error.message);return;}
+  task.estado=next;
+  // Re-render pestaña
+  const body=document.getElementById('cd-fd-body');
+  if(body)body.innerHTML=cdProgresoHTML(CONTENIDO.find(c=>String(c.id)===String(contenidoId)),tasks);
+}
